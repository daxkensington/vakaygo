# ============================================================================
# vakaygo environment variables
# ============================================================================
# Copy to .env.local for local dev. Set in Vercel dashboard for prod.
# All required variables are validated at runtime in lib/env.ts.

# --- REQUIRED ---
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
AUTH_SECRET=replace-me-with-32-plus-character-random-string

# --- Observability ---
NEXT_PUBLIC_SENTRY_DSN=https://...@...ingest.sentry.io/...

# --- Maps ---
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# --- Payments ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Email ---
RESEND_API_KEY=re_...

# --- SMS / Phone verification ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...

# --- OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- AI providers (any subset) ---
XAI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Storage ---
BLOB_READ_WRITE_TOKEN=

# --- Web Push ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
